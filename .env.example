# Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=your-telegram-bot-token

# Claude API Key
CLAUDE_API_KEY=your-claude-api-key

# Comma-separated Telegram user IDs allowed to interact
ALLOWED_USER_IDS=123456789

# Default location (for weather, etc.)
LOCATION_LAT=32.08
LOCATION_LON=34.78
TIMEZONE=Asia/Jerusalem

# Git auto-push (set to "true" to enable)
GIT_AUTO_PUSH=true
GIT_BRANCH=main

# Optional: football-data.org API key (free tier)
FOOTBALL_API_KEY=

# Optional: additional whitelisted domains (comma-separated)
EXTRA_DOMAINS=
